# WordPress API URL
# ローカル開発時
WORDPRESS_API_URL=http://localhost:8080/wp-json/wp/v2

# ステージング環境（クラウドWordPressのURLに変更）
# WORDPRESS_API_URL=https://your-staging-domain.com/wp-json/wp/v2

# 本番環境
# WORDPRESS_API_URL=https://api.wa-ve.jp/wp-json/wp/v2

# Contact フォーム（Resend）
# https://resend.com/api-keys で発行
RESEND_API_KEY=
# 送信先（省略時 info@wa-ve.jp）
# CONTACT_TO_EMAIL=info@wa-ve.jp
# 差出人。Resend でドメイン認証後に noreply@wa-ve.jp 等へ変更（省略時 onboarding@resend.dev）
# CONTACT_FROM_EMAIL=noreply@wa-ve.jp
